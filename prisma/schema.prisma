generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(MANAGER)
  createdAt DateTime @default(now())
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String
  color     String   @default("#2563eb")
  createdAt DateTime @default(now())
  players   Player[]
  staff     Staff[]
}

model Player {
  id        Int      @id @default(autoincrement())
  name      String
  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id])
  createdAt DateTime @default(now())
}

model Staff {
  id        Int      @id @default(autoincrement())
  name      String
  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id])
  createdAt DateTime @default(now())
}

enum Role {
  MANAGER
  ADMIN
}
