generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(MANAGER)
  createdAt DateTime @default(now())
}

model Team {
  id            Int      @id @default(autoincrement())
  name          String
  createdAt     DateTime @default(now())
  players       Player[]
  staffs        Staff[]
  competitionId Int
  competition   Competition   @relation(fields: [competitionId], references: [id])
}

model Player {
  id        Int      @id @default(autoincrement())
  name      String
  number    String
  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id])
  createdAt DateTime @default(now())
}

model Staff {
  id        Int      @id @default(autoincrement())
  name      String
  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id])
  createdAt DateTime @default(now())
}

enum Role {
  MANAGER
  ADMIN
}

model Competition {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  teams     Team[]
}