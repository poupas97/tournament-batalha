generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(MANAGER)
  createdAt DateTime @default(now())
}

model Team {
  id            Int      @id @default(autoincrement())
  name          String
  createdAt     DateTime @default(now())
  players       Player[]
  staffs        Staff[]
  competitionId Int
  competition   Competition   @relation(fields: [competitionId], references: [id])
  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")

  events MatchEvent[]
}

model Player {
  id        Int      @id @default(autoincrement())
  name      String
  number    String
  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id])
  createdAt DateTime @default(now())

  events MatchEvent[]
}

model Staff {
  id        Int      @id @default(autoincrement())
  name      String
  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id])
  createdAt DateTime @default(now())

  events MatchEvent[]
}

enum Role {
  MANAGER
  ADMIN
}

model Competition {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  teams     Team[]
  matches     Match[]
}

model Match {
  id Int @id @default(autoincrement())

  competitionId Int
  competition Competition @relation(fields: [competitionId], references: [id])

  homeTeamId Int?
  homeTeam Team? @relation("HomeTeam", fields: [homeTeamId], references: [id])

  awayTeamId Int?
  awayTeam Team? @relation("AwayTeam", fields: [awayTeamId], references: [id])

  round String

  date DateTime

  status MatchStatus @default(SCHEDULED)

  events MatchEvent[]

  createdAt DateTime @default(now())
}

model MatchEvent {
  id Int @id @default(autoincrement())

  matchId Int
  match Match @relation(fields: [matchId], references: [id])

  teamId Int?
  team Team? @relation(fields: [teamId], references: [id])

  playerId Int?
  player Player? @relation(fields: [playerId], references: [id])

  staffId Int?
  staff Staff? @relation(fields: [staffId], references: [id])

  minute Int?

  type MatchEventType

  createdAt DateTime @default(now())
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELED
}

enum MatchEventType {
  GOAL
  OWN_GOAL
  PENALTY_GOAL

  YELLOW_CARD
  RED_CARD

  TIMEOUT

  RT_START
  RT_HALF_TIME
  RT_END
  ET_START
  ET_HALF_TIME
  ET_END
  PENALTY
}